{
    "name": "glowgaia/grabbit",
    "description": "A SaloonPHP-based SDK for Gaia Online's GSI API",
    "type": "library",
    "license": "MPL-2.0",
    "autoload": {
        "psr-4": {
            "GlowGaia\\Grabbit\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Sheldon Corcoran",
            "email": "awesomolocity@gmail.com"
        }
    ],
    "require-dev": {
        "tightenco/duster": "^3.4",
        "phpunit/phpunit": "^13.1.6",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0"
    },
    "require": {
        "saloonphp/saloon": "^4.0",
        "illuminate/support": "^13.4",
        "illuminate/collections": "^13.4",
        "symfony/serializer": "^8.0",
        "symfony/property-access": "^8.0"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "duster:lint": "vendor/bin/duster lint",
        "duster:fix": "vendor/bin/duster fix",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=512M"
    }
}
